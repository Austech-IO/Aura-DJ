rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity Validations
    function isValidPlaylist(data) {
      return data.keys().hasAll(['userId', 'mood', 'energyLevel', 'themeColor', 'title', 'description', 'tracks', 'createdAt'])
        && data.keys().size() == 8
        && data.userId == request.auth.uid
        && data.mood is string && data.mood.size() <= 100
        && data.energyLevel in ['low', 'medium', 'high']
        && data.themeColor is string && data.themeColor.size() <= 30
        && data.title is string && data.title.size() <= 500
        && data.description is string && data.description.size() <= 2000
        && data.tracks is list && data.tracks.size() > 0 && data.tracks.size() <= 20
        && data.createdAt == request.time;
    }

    // Collection: Playlists
    match /playlists/{playlistId} {
      allow get: if isSignedIn() && isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(playlistId)
        && isValidPlaylist(incoming());
        
      allow delete: if isSignedIn() && isOwner(existing().userId);
      
      // Updates are not supported for playlists in this app - they are static once generated
      allow update: if false;
    }
  }
}
