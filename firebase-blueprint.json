{
  "entities": {
    "Playlist": {
      "title": "Music Playlist",
      "description": "A curated list of songs generated by the AI DJ based on user mood.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "mood": { "type": "string" },
        "energyLevel": { "type": "string", "enum": ["low", "medium", "high"] },
        "themeColor": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "tracks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "artist": { "type": "string" },
              "album": { "type": "string" },
              "genre": { "type": "string" },
              "duration": { "type": "string" },
              "year": { "type": "string" },
              "searchQuery": { "type": "string" },
              "thumbnailHint": { "type": "string" },
              "youtubeId": { "type": "string" }
            },
            "required": ["title", "artist", "album", "genre", "duration", "year", "searchQuery"]
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "mood", "energyLevel", "themeColor", "title", "description", "tracks", "createdAt"]
    }
  },
  "firestore": {
    "playlists": {
      "schema": "Playlist",
      "description": "Collection storing all AI-generated music playlists."
    }
  }
}
